# Copy to apps/api/.env
#
# --- Local Docker ---
# DATABASE_URL="postgresql://localbms:localbms@localhost:5433/localbms?schema=public"
#
# --- Supabase (copy exact URI from Dashboard → Project Settings → Database) ---
# Direct (use for prisma db push / migrate):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
#
# If direct fails with P1001, use Session pooler from dashboard (port 5432):
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://localbms:localbms@localhost:5433/localbms?schema=public"
JWT_SECRET="dev-secret-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
PORT=4000
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173"
MOCK_PAYMENTS=true
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
